services:
  journal-discovery:
    env_file:
      - .env
    build:
      context: ../..
      dockerfile: deployment/container/Dockerfile
      args:
        SITE_URL: ${SITE_URL}
    image: ${IMAGE_NAME}
    container_name: ${CONTAINER_NAME}
    restart: unless-stopped
    ports:
      - "${HOST_PORT}:80"